# Tushare Pro API（https://tushare.pro）
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_URL=http://your_tushare_api_url/

# 代理（yfinance 等访问境外服务时使用）
PROXY_URL=http://127.0.0.1:7897

# Telegram Bot 推送
# 1. 向 @BotFather 创建 Bot，获取 bot_token
# 2. 向 @userinfobot 获取自己的 chat_id
# 3. 先给 Bot 发一条消息（激活 chat）再启动推送
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Google AI（Gemini）— AI 市场解读摘要使用
GOOGLE_API_KEY=your_google_api_key_here
